# Copy to .env and fill in real secrets:  cp env.example .env
# docker compose reads .env automatically (.env is git-ignored).

# Mongo root (admin) user — created on first boot
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASSWD=veryStringPassword

# Application user — gets readWrite on the okydook database
DB_USERNAME=okydook
DB_PASSWORD=mypassword
