# =============================================================================
# cluster.env — PostgreSQL HA cluster variables
# =============================================================================
# Copy to cluster.env and adapt. Sourced by the deployment script and by the
# guide (section 0). DO NOT commit cluster.env (it contains the secrets).
#   cp cluster.env.example cluster.env && chmod 600 cluster.env
# =============================================================================

# --- Cluster identity ------------------------------------------------------
CLUSTER_NAME="postgresql-cluster"   # Patroni scope
PG_VERSION="18"                     # PostgreSQL major version (bin_dir)
ETCD_VERSION="v3.6.12"               # downloaded etcd binary

# --- Network ---------------------------------------------------------------
SUBNET="192.168.11.0/24"           # cluster subnet (pg_hba)
VIP="192.168.11.50"               # floating virtual IP (application entry point)
IFACE="ens3"                      # interface carrying the VIP (ip link show)
APP_SUBNET="192.168.11.0/24"      # client subnet; if = SUBNET, already covered

# --- Nodes (name + IP) -----------------------------------------------------
DB1_NAME="db1"; DB1_IP="192.168.11.45"   # initial MASTER, VRRP priority 100
DB2_NAME="db2"; DB2_IP="192.168.11.46"   # BACKUP, VRRP priority 90
DB3_NAME="db3"; DB3_IP="192.168.11.47"   # BACKUP, VRRP priority 80

# --- Ports (normally unchanged) --------------------------------------------
ETCD_CLIENT_PORT="2379"
ETCD_PEER_PORT="2380"
PG_HAPROXY_PORT="5432"   # port exposed to the applications
PG_PATRONI_PORT="5433"   # internal PostgreSQL port managed by Patroni
PATRONI_API_PORT="8008"

# --- VRRP priorities (Keepalived) ------------------------------------------
DB1_VRRP_PRIORITY="100"
DB2_VRRP_PRIORITY="90"
DB3_VRRP_PRIORITY="80"
VRRP_ROUTER_ID="51"      # identical on all 3 nodes

# --- Certificate subject (X.509) -------------------------------------------
CERT_COUNTRY="TG"
CERT_STATE="MARITIME"
CERT_LOCALITY="LOME"
CERT_ORG="MESPTN"
CERT_OU="ATD"

# --- Secrets (generate: openssl rand -base64 24 ; identical on all 3 nodes)-
# VRRP auth_pass: max 8 characters.
PG_SUPERUSER_PASSWORD="CHANGE_ME_SUPERUSER"
PG_REPLICATOR_PASSWORD="CHANGE_ME_REPLICATOR"
PATRONI_RESTAPI_PASSWORD="CHANGE_ME_RESTAPI"
VRRP_AUTH_PASS="CHANGE_ME"
